{
  "name": "collab-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time collaborative document editor",
  "scripts": {
    "prepare": "husky",
    "commit": "git-cz",
    "dev": "turbo dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules packages/*/node_modules frontend/node_modules backend/node_modules",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:studio": "pnpm --filter backend db:studio",
    "db:seed": "pnpm --filter backend db:seed"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "commitizen": "^4.3.1",
    "concurrently": "^9.1.2",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.5.3",
    "turbo": "^2.8.13"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
